{
  "manifest_version": 3,
  "name": "Meeting Cost Clock",
  "description": "Live cost counter for meetings — see exactly what this meeting is costing your team in real time",
  "version": "1.0.0",
  "permissions": ["storage"],
  "action": {
    "default_popup": "popup.html",
    "default_icon": { "32": "icons/icons32.png" }
  },
  "icons": { "32": "icons/icons32.png" },
  "background": { "service_worker": "background.js" },
  "host_permissions": [
    "https://generativelanguage.googleapis.com/*",
    "https://openrouter.ai/*"
  ]
}
